### 1. Authentication | Argo CD API server
#### 1.1 if you do NOT pass JWT -> it fails
# curl -k https://localhost:8080/api/v1/applications
GET https://localhost:8080/api/v1/applications

### 1.2 ❌NOT -- through username/password❌
# curl -k https://localhost:8080/api/v1/applications -H "Authorization: Basic <AUTH_PASSWORD_BASE_64>"
GET https://localhost:8080/api/v1/applications
Authorization: Basic admin {{adminpassword}}

### 1.3 works -- via -- JWT
# curl -k https://localhost:8080/api/v1/applications -H "Authorization: Bearer <PREVIOUS_GOT_BEARER_TOKEN>"
GET https://localhost:8080/api/v1/applications
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJhcmdvY2QiLCJzdWIiOiJhZG1pbjpsb2dpbiIsImV4cCI6MTc3ODA4Mjc2NiwibmJmIjoxNzc3OTk2MzY2LCJpYXQiOjE3Nzc5OTYzNjYsImp0aSI6IjQwYTExMWNmLWFhMzUtNDU5MS1hNGE5LWE0MDA2MmM3YmNlMCJ9.usQ62vf2-7bBqdXIHbFAuwS7syZbTbIUWzeiUF3SfEE

###

### 2. ways to be obtain/manage JWT
#### 2.1 local users / contain username/password /
# curl -k -H "Content-Type: application/json" https://localhost:8080/api/v1/session -d '{"username":"admin","password":"<ARGO_CD_INITIAL_ADMIN_PASSWORD>"}'
POST https://localhost:8080/api/v1/session
Content-Type: application/json

{
  "username": "admin",
  "password": "LzT2fZ18e-bZWTlw"
}

